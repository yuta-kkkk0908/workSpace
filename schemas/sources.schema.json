{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sources",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "type", "source", "path", "url", "collectedAt", "status", "tags"],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "type": {
        "type": "string",
        "minLength": 1
      },
      "source": {
        "type": "string",
        "minLength": 1
      },
      "path": {
        "type": "string",
        "minLength": 1
      },
      "url": {
        "type": "string"
      },
      "collectedAt": {
        "type": "string",
        "format": "date-time"
      },
      "status": {
        "type": "string",
        "enum": ["new", "organized", "archived"]
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "additionalProperties": false
  }
}
